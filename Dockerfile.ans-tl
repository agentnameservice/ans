# Multi-stage build for ans-tl. Mirrors Dockerfile.ans-ra's structure
# so both binaries deploy the same way.
#
# Build:  docker build -f Dockerfile.ans-tl -t ans-tl:local .
# Run:    docker run --rm -p 18081:18081 \
#           -v "$PWD/config:/etc/ans-tl:ro" \
#           -v "$PWD/data:/var/lib/ans-tl" \
#           ans-tl:local --config /etc/ans-tl/tl.yaml
FROM golang:1.26-alpine AS build
WORKDIR /src
# Pure-Go build (modernc.org/sqlite) — no C toolchain, fully static binary.
ENV CGO_ENABLED=0

COPY go.mod go.sum ./
RUN go mod download

COPY . .
ARG VERSION=dev
ARG COMMIT=unknown
ARG DATE=unknown
RUN go build \
    -trimpath \
    -ldflags "-s -w -X main.version=${VERSION} -X main.commit=${COMMIT} -X main.date=${DATE}" \
    -o /out/ans-tl ./cmd/ans-tl

FROM alpine:3.23
RUN apk add --no-cache ca-certificates tzdata \
 && addgroup -S ans && adduser -S -G ans ans \
 && mkdir -p /var/lib/ans-tl /etc/ans-tl \
 && chown -R ans:ans /var/lib/ans-tl
USER ans
WORKDIR /var/lib/ans-tl
COPY --from=build /out/ans-tl /usr/local/bin/ans-tl
EXPOSE 18081
ENTRYPOINT ["/usr/local/bin/ans-tl"]
CMD ["--config", "/etc/ans-tl/tl.yaml"]
